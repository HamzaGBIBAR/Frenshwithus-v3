# Local: postgresql://user:password@localhost:5432/frenchwithus
# Railway: use ${{Postgres.DATABASE_URL}} from dashboard; sslmode=require is auto-appended
DATABASE_URL="postgresql://user:password@localhost:5432/frenchwithus"

# OBLIGATOIRE en production. Générer: openssl rand -base64 48 (≥64 caractères)
# Ne jamais commiter une vraie clé. Définir dans Railway Variables.
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-64-chars-recommended"

NODE_ENV=production
PORT=3001

# PRODUCTION: Définir l'URL du frontend pour CORS (Railway Variables).
# Si frontend et backend sur le même domaine, RAILWAY_PUBLIC_DOMAIN suffit.
# Sinon: FRONTEND_URL=https://votre-app.up.railway.app (ou plusieurs, séparés par des virgules)
# FRONTEND_URL=https://frenshwithus-v2-production.up.railway.app

# Optionnel: Sentry pour le monitoring des erreurs
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Optionnel: OpenAI pour le chatbot AI (assistant sur la page d'accueil)
# Sans clé, le chatbot utilise des réponses prédéfinies adaptées à French With Us.
# OPENAI_API_KEY=sk-...
# OPENAI_CHAT_MODEL=gpt-4o-mini

# Cloudinary (avatars) – requis pour l'upload de photos de profil
# Créer un compte sur cloudinary.com, puis récupérer les credentials dans le dashboard
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
